{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": ["tests/examples", "scripts", "playwright.config.ts", "tests/seed.spec.ts"]
}


